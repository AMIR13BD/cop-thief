# Secrets & credentials — NEVER commit
.env
credentials.json
token.json
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# Runtime artifacts (keep the folders, ignore their contents)
results/logs/*
results/reports/*
results/screenshots/*
!results/logs/.gitkeep
!results/reports/.gitkeep
!results/screenshots/.gitkeep

# OS / editor
.DS_Store
.idea/
.vscode/
