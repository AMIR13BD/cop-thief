# ─── Copy to .env and fill in. .env is git-ignored; never commit real secrets. ───

# ===== LLM (orchestrator/client side — approach #1: cloud API, recommended) =====
# Anthropic API key used by the orchestrator to drive agent reasoning.
# Leave empty to run the built-in deterministic heuristic strategy (no network, no cost).
ANTHROPIC_API_KEY=
# Model id (overrides config.yaml -> llm.model). Opus 4.8 by default; Haiku is a cheaper option.
COP_THIEF_LLM_MODEL=claude-opus-4-8

# ===== MCP server auth (token sent in the Authorization: Bearer <token> header) =====
# Token THIS team's servers require from incoming callers.
MCP_AUTH_TOKEN=
# Token used when OUR client calls the OTHER team's servers (bonus match).
MCP_PEER_TOKEN=

# ===== MCP server bind config (local stage) =====
COP_SERVER_HOST=127.0.0.1
COP_SERVER_PORT=8101
THIEF_SERVER_HOST=127.0.0.1
THIEF_SERVER_PORT=8102

# ===== Gmail API (final report email) =====
# Path to the OAuth Desktop client file downloaded from Google Cloud Console.
GMAIL_CREDENTIALS_FILE=credentials.json
# Where the refreshable OAuth token is cached after first consent.
GMAIL_TOKEN_FILE=token.json
# Destination address fixed by the assignment.
REPORT_RECIPIENT=rmisegal+uoh26b@gmail.com
